<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>SetupDoctor.App</RootNamespace>
    <AssemblyName>SetupDoctor</AssemblyName>
    <!-- アイコン未デザインのため既定アイコンを使用。デザイン確定後に Resources\app.ico を追加して有効化する -->
    <!-- バージョン情報 -->
    <Version>0.1.1</Version>
    <AssemblyVersion>0.1.1.0</AssemblyVersion>
    <FileVersion>0.1.1.0</FileVersion>
    <InformationalVersion>0.1.1-beta</InformationalVersion>
    <Company>非公式ツール（Anthropic社製品ではありません）</Company>
    <Product>Claude Code セットアップ診断ツール</Product>
    <Description>Claude Code のセットアップを診断・修復する非公式Windowsコンパニオンツール。</Description>
    <Copyright>Copyright © 2026 contributors</Copyright>
  </PropertyGroup>

  <!-- self-contained single-file publish（win-x64 用）-->
  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PublishReadyToRun>false</PublishReadyToRun>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <!-- WPFのネイティブ依存(PresentationNative等)を単一exeに埋め込むために必須。
         これが無いと配布した.exe単体では起動時に依存解決に失敗し、ウィンドウが開かないまま終了する -->
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <DebugType>embedded</DebugType>
    <TrimmerRootDescriptor></TrimmerRootDescriptor>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\SetupDoctor.Core\SetupDoctor.Core.csproj" />
    <ProjectReference Include="..\SetupDoctor.Infrastructure.Windows\SetupDoctor.Infrastructure.Windows.csproj" />
    <ProjectReference Include="..\SetupDoctor.Reporting\SetupDoctor.Reporting.csproj" />
  </ItemGroup>

</Project>
