<UserControl x:Class="SetupDoctor.App.Views.CompletionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.Name="完了">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="480">
            <TextBlock Text="{StaticResource CompletionTitle}"
                       FontSize="20" FontWeight="Bold" Foreground="#1A2B4C"
                       TextAlignment="Center" Margin="0,0,0,16"/>

            <TextBlock Text="{Binding CompletionMessage}"
                       FontSize="14" Foreground="#333"
                       TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,8"
                       AutomationProperties.LiveSetting="Polite"/>

            <TextBlock Text="{Binding OverallHeadline}"
                       FontSize="12" Foreground="#666"
                       TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,28"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                <Button Content="{StaticResource CompletionReScan}"
                        Command="{Binding StartScanCommand}"
                        Margin="0,0,8,0" Padding="18,9"
                        Background="#00A99D" Foreground="White" BorderThickness="0"
                        AutomationProperties.Name="もう一度診断"/>
                <Button Content="{StaticResource CompletionExportReport}"
                        Command="{Binding SaveReportCommand}"
                        Margin="0,0,8,0" Padding="18,9"
                        AutomationProperties.Name="診断結果を保存"/>
                <Button Content="{StaticResource CompletionBackToStart}"
                        Command="{Binding BackToStartCommand}"
                        Padding="18,9"
                        AutomationProperties.Name="スタートに戻る"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0"
                        Visibility="{Binding LastReportPath, Converter={StaticResource NullToVisibilityConverter}}">
                <TextBlock Text="{Binding LastReportPath, StringFormat='保存しました: {0}'}"
                           FontSize="11" Foreground="#666" Margin="0,0,8,0"/>
                <Button Content="{StaticResource ResultsOpenFolder}"
                        Command="{Binding OpenReportFolderCommand}"
                        FontSize="11" Padding="8,2"
                        AutomationProperties.Name="保存先を開く"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
