<UserControl x:Class="SetupDoctor.App.Views.RemediationExecutingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.Name="修復を実行中">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="520">
            <TextBlock Text="{StaticResource RemediationExecutingTitle}"
                       FontSize="18" FontWeight="SemiBold" Foreground="#1A2B4C"
                       TextAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="{Binding BusyMessage}"
                       FontSize="12" Foreground="#555"
                       TextAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="{StaticResource RemediationExecutingCancelNote}"
                       FontSize="11" Foreground="#888" TextWrapping="Wrap"
                       TextAlignment="Center" Margin="0,0,0,20"/>

            <ProgressBar IsIndeterminate="True" Width="360" Height="6" Margin="0,0,0,20"
                         AutomationProperties.Name="修復実行中"/>

            <ListView ItemsSource="{Binding RemediationPlan}" MaxHeight="240"
                      BorderThickness="0" Background="Transparent"
                      AutomationProperties.Name="修復項目の進捗一覧">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="4,4">
                            <TextBlock Text="{Binding Title}" Width="260" FontSize="12" Foreground="#333"/>
                            <TextBlock Text="{Binding StatusText}" FontSize="12" FontWeight="SemiBold" Foreground="#1A2B4C"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Button Content="キャンセル"
                    Command="{Binding CancelRemediationCommand}"
                    HorizontalAlignment="Center" Margin="0,16,0,0" Padding="20,8"
                    AutomationProperties.Name="修復をキャンセル"/>
        </StackPanel>
    </Grid>
</UserControl>
