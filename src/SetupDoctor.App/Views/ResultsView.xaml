<UserControl x:Class="SetupDoctor.App.Views.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.Name="診断結果">
    <DockPanel Margin="16">
        <!-- 全体判定バナー -->
        <Border DockPanel.Dock="Top" CornerRadius="4" Padding="12,8" Margin="0,0,0,12">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#E8F5E9"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Readiness}" Value="Repairable">
                            <Setter Property="Background" Value="#FFF3E0"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Readiness}" Value="UserActionRequired">
                            <Setter Property="Background" Value="#FFF9C4"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Readiness}" Value="ITActionRequired">
                            <Setter Property="Background" Value="#FCE4EC"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Readiness}" Value="Unsupported">
                            <Setter Property="Background" Value="#F3E5F5"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding OverallLabel}"
                       FontSize="15" FontWeight="SemiBold" Foreground="#222"
                       AutomationProperties.LiveSetting="Polite"/>
        </Border>

        <!-- アクションボタン -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{StaticResource ResultsReScan}"
                    Command="{Binding StartScanCommand}"
                    Margin="0,0,8,0" Padding="16,8"
                    AutomationProperties.Name="再スキャン"/>
            <Button Content="{StaticResource ResultsExportReport}"
                    Command="{Binding ShowReportCommand}"
                    Padding="16,8"
                    AutomationProperties.Name="レポートを保存"/>
        </StackPanel>

        <!-- 結果リスト -->
        <ListView ItemsSource="{Binding Results}"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  AutomationProperties.Name="チェック結果一覧">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="チェック項目" Width="200"
                                    DisplayMemberBinding="{Binding CheckId}"/>
                    <GridViewColumn Header="状態" Width="100"
                                    DisplayMemberBinding="{Binding StatusLabel}"/>
                    <GridViewColumn Header="詳細" Width="300"
                                    DisplayMemberBinding="{Binding DetailCode}"/>
                    <GridViewColumn Header="所要時間" Width="90"
                                    DisplayMemberBinding="{Binding Duration}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</UserControl>
