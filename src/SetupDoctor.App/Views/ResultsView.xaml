<UserControl x:Class="SetupDoctor.App.Views.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.Name="診断結果">
    <DockPanel Margin="20">
        <!-- 全体判定バナー：見出し＋補足（docs/03 3.4 S-03） -->
        <Border DockPanel.Dock="Top" CornerRadius="6" Padding="16,14" Margin="0,0,0,10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#E8F5E9"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Readiness}" Value="Repairable">
                            <Setter Property="Background" Value="#FFF3E0"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Readiness}" Value="UserActionRequired">
                            <Setter Property="Background" Value="#FFF9C4"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Readiness}" Value="ITActionRequired">
                            <Setter Property="Background" Value="#FCE4EC"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Readiness}" Value="Unsupported">
                            <Setter Property="Background" Value="#F3E5F5"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Readiness}" Value="Unknown">
                            <Setter Property="Background" Value="#ECEFF1"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <TextBlock Text="{Binding OverallHeadline}"
                           FontSize="20" FontWeight="Bold" Foreground="#1A2B4C"
                           AutomationProperties.LiveSetting="Polite"/>
                <TextBlock Text="{Binding OverallSub}"
                           FontSize="13" Foreground="#444" Margin="0,4,0,0"/>
                <TextBlock Text="{Binding PassSummaryText}"
                           FontSize="12" Foreground="#666" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- アクションボタン -->
        <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{StaticResource ResultsRunRepair}"
                        Command="{Binding GoToRemediationReviewCommand}"
                        Margin="0,0,8,0" Padding="18,9"
                        Background="#00A99D" Foreground="White" BorderThickness="0"
                        AutomationProperties.Name="自動で直す"
                        Visibility="{Binding HasRepairableItems,
                            Converter={StaticResource BoolToVisibilityConverter}}"/>
                <Button Content="{StaticResource ResultsReScan}"
                        Command="{Binding StartScanCommand}"
                        Margin="0,0,8,0" Padding="16,8"
                        AutomationProperties.Name="もう一度診断"/>
                <Button Content="{StaticResource ResultsExportReport}"
                        Command="{Binding SaveReportCommand}"
                        Padding="16,8"
                        AutomationProperties.Name="診断結果を保存"/>
            </StackPanel>

            <!-- 保存完了の案内 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0"
                        Visibility="{Binding LastReportPath, Converter={StaticResource NullToVisibilityConverter}}">
                <TextBlock Text="{Binding LastReportPath, StringFormat='保存しました: {0}'}"
                           FontSize="11" Foreground="#666" Margin="0,0,8,0"/>
                <Button Content="{StaticResource ResultsOpenFolder}"
                        Command="{Binding OpenReportFolderCommand}"
                        FontSize="11" Padding="8,2"
                        AutomationProperties.Name="保存先を開く"/>
            </StackPanel>

            <ToggleButton IsChecked="{Binding ShowTechnicalDetail, Mode=TwoWay}"
                          HorizontalAlignment="Left" Margin="0,12,0,0"
                          FontSize="11" Foreground="#1E88E5" Background="Transparent" BorderThickness="0"
                          Cursor="Hand"
                          AutomationProperties.Name="技術的な詳細の表示切り替え">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton">
                        <Setter Property="Content" Value="{StaticResource ResultsShowDetail}"/>
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Content" Value="{StaticResource ResultsHideDetail}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>
            </ToggleButton>
        </StackPanel>

        <!-- メイン: 対応が必要な項目を平易な説明つきで表示 -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ListView Grid.Row="0" ItemsSource="{Binding ActionableResults}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      BorderThickness="0" Background="Transparent"
                      AutomationProperties.Name="対応が必要な項目一覧">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="4,10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#1A2B4C" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding RequirementLevelLabel}"
                                                   FontSize="10" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="14" FontWeight="SemiBold" Foreground="#1A2B4C"
                                               Margin="8,0,8,0"/>
                                    <TextBlock Text="{Binding StatusLabel}"
                                               FontSize="12" Foreground="#B71C1C" FontWeight="SemiBold"/>
                                </StackPanel>
                                <TextBlock Text="{Binding FriendlySummary}"
                                           FontSize="12" Foreground="#333"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- 技術的な詳細（折りたたみ、既定は非表示） -->
            <Border Grid.Row="1" Margin="0,12,0,0" Padding="8" Background="#FAFAFA"
                    Visibility="{Binding ShowTechnicalDetail, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="技術的な詳細（サポートへの問い合わせ時に利用してください）"
                               FontSize="11" Foreground="#888" Margin="0,0,0,6"/>
                    <ListView ItemsSource="{Binding Results}" MaxHeight="220"
                              FontFamily="Consolas" FontSize="11"
                              AutomationProperties.Name="全チェック技術詳細一覧">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Check ID" Width="140"
                                                DisplayMemberBinding="{Binding CheckId}"/>
                                <GridViewColumn Header="Status" Width="90"
                                                DisplayMemberBinding="{Binding Status}"/>
                                <GridViewColumn Header="Detail Code" Width="260"
                                                DisplayMemberBinding="{Binding DetailCode}"/>
                                <GridViewColumn Header="Duration" Width="90"
                                                DisplayMemberBinding="{Binding Duration}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
